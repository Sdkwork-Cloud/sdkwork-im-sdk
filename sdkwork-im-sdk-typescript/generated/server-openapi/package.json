  "scripts": {
    "build": "tsc --emitDeclarationOnly && vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sdkwork/sdk-common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "catalog:",
    "vite": "8.0.3",
    "vite-plugin-dts": "catalog:"
  },
  "keywords": [
    "sdk",
    "api",
    "backend",
    "sdkwork"
  ]
}
