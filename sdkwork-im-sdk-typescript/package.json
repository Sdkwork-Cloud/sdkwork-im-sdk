{
  "name": "@sdkwork/im-sdk",
  "version": "0.1.0",
  "description": "Unified IM SDK package with embedded OpenAPI-generated transport and handwritten realtime/business modules",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@sdkwork/sdk-common": "^1.0.2"
  },
  "scripts": {
    "assemble": "call \"%npm_node_execpath%\" ./bin/package-task.mjs assemble || \"$npm_node_execpath\" ./bin/package-task.mjs assemble || node ./bin/package-task.mjs assemble",
    "clean": "call \"%npm_node_execpath%\" ./bin/package-task.mjs clean || \"$npm_node_execpath\" ./bin/package-task.mjs clean || node ./bin/package-task.mjs clean",
    "typecheck": "call \"%npm_node_execpath%\" ./bin/package-task.mjs typecheck || \"$npm_node_execpath\" ./bin/package-task.mjs typecheck || node ./bin/package-task.mjs typecheck",
    "build": "call \"%npm_node_execpath%\" ./bin/package-task.mjs build || \"$npm_node_execpath\" ./bin/package-task.mjs build || node ./bin/package-task.mjs build",
    "smoke": "call \"%npm_node_execpath%\" ./bin/package-task.mjs smoke || \"$npm_node_execpath\" ./bin/package-task.mjs smoke || node ./bin/package-task.mjs smoke",
    "test": "call \"%npm_node_execpath%\" ./bin/package-task.mjs test || \"$npm_node_execpath\" ./bin/package-task.mjs test || node ./bin/package-task.mjs test"
  }
}
