{
  "name": "@sdkwork/im-sdk",
  "version": "0.1.0",
  "description": "Internal composed authoring workspace for the IM TypeScript SDK",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#generated-sdk": "./.generated/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "typecheck": "call \"%npm_node_execpath%\" ./bin/package-task.mjs typecheck || \"$npm_node_execpath\" ./bin/package-task.mjs typecheck || node ./bin/package-task.mjs typecheck",
    "build": "call \"%npm_node_execpath%\" ./bin/package-task.mjs build || \"$npm_node_execpath\" ./bin/package-task.mjs build || node ./bin/package-task.mjs build",
    "test": "call \"%npm_node_execpath%\" ./bin/package-task.mjs test || \"$npm_node_execpath\" ./bin/package-task.mjs test || node ./bin/package-task.mjs test"
  }
}
