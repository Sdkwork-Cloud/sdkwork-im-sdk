{
  "name": "@openchat/sdkwork-im-wukongim-adapter",
  "version": "1.0.11",
  "description": "Handwritten WuKongIM adapter layer for the OpenChat TypeScript SDK workspace",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../../node_modules/vite/bin/vite.js build",
    "typecheck": "node ../../../node_modules/typescript/bin/tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "wukongimjssdk": "^1.3.5"
  }
}
